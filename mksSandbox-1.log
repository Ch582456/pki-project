from flask import Flask, request, redirect, render_template_string
from datetime import datetime

app = Flask(__name__)

certificates = []

HTML = """
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>PKI Manager</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    background: #f4f6f9;
}

.card {
    border-radius: 10px;
}

.badge-valid {
    background: #d4edda;
    color: green;
    padding: 6px 10px;
    border-radius: 5px;
}

.badge-revoked {
    background: #f8d7da;
    color: red;
    padding: 6px 10px;
    border-radius: 5px;
}

.dark-csr {
    background:#2b2b2b;
    color:white;
    height:200px;
}
</style>

</head>

<body>

<div class="container mt-4">

<!-- HEADER -->
<div class="card p-4 mb-3 shadow-sm">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h3>✅ Registre des Certificats Émis</h3>
            <p class="text-muted">Historique complet des certificats signés</p>
        </div>
        <a href="#form" class="btn btn-primary">+ Émettre</a>
    </div>
</div>

<!-- FORM -->
<div id="form" class="card p-4 mb-4 shadow-sm">

    <h3>✍️ Émettre un Certificat (Signer un CSR)</h3>
    <p class="text-muted">
        Soumettez une demande de signature de certificat (CSR).
        L'Autorité Intermédiaire traitera la demande et signera le certificat final.
    </p>

    <form method="POST">

        <label class="form-label mt-3"><b>Nom Commun (CN)</b></label>
        <input class="form-control" type="text" name="cn"
            placeholder="ex: mon-serveur.local ou utilisateur1" required>

        <small class="text-muted">
            Ce nom servira d'identifiant pour nommer le certificat.
        </small>

        <label class="form-label mt-3"><b>Profil / Type</b></label>
        <select class="form-control">
            <option>Certificat Serveur (SSL/TLS HTTPS)</option>
            <option>Certificat Client</option>
        </select>

        <small class="text-muted">
            Définit l'usage des clés dans OpenSSL.
        </small>

        <label class="form-label mt-3"><b>CSR</b></label>
        <textarea class="form-control dark-csr"
            name="csr" placeholder="-----BEGIN CERTIFICATE REQUEST-----"></textarea>

        <button class="btn btn-primary mt-3">Signer et Générer</button>

    </form>

</div>

<!-- TABLE -->
<div class="card p-4 shadow-sm">

<table class="table table-hover table-bordered text-center align-middle">

<thead class="table-light">
<tr>
    <th>Status</th>
    <th>N° Série</th>
    <th>Nom</th>
    <th>Date Émission</th>
    <th>Date Révocation</th>
    <th>Actions</th>
</tr>
</thead>

<tbody>

{% for cert in certs %}
<tr>

<td>
{% if cert.status == "Valid" %}
    <span class="badge-valid">● Valide</span>
{% else %}
    <span class="badge-revoked">● Révoqué</span>
{% endif %}
</td>

<td><b>{{ cert.id }}</b></td>
<td>{{ cert.cn }}</td>

<td>{{ cert.date_emission }}</td>
<td>{{ cert.date_revocation }}</td>

<td>

<button class="btn btn-outline-primary btn-sm">📥 Certificat</button>

{% if cert.status == "Valid" %}
<form method="POST" action="/revoke/{{ cert.id }}" style="display:inline;">
    <button class="btn btn-outline-danger btn-sm">🔴 Révoquer</button>
</form>
{% else %}
<button class="btn btn-secondary btn-sm" disabled>Révoqué</button>
{% endif %}

</td>

</tr>
{% endfor %}

</tbody>

</table>

</div>

</div>

</body>
</html>
"""

@app.route("/", methods=["GET","POST"])
def home():
    if request.method == "POST":
        cn = request.form["cn"]

        certificates.append({
            "id": len(certificates) + 2000,
            "cn": cn,
            "status": "Valid",
            "date_emission": datetime.now().strftime("%Y-%m-%d"),
            "date_revocation": "-"
        })

    return render_template_string(HTML, certs=certificates)

@app.route("/revoke/<int:id>", methods=["POST"])
def revoke(id):
    for cert in certificates:
        if cert["id"] == id:
            cert["status"] = "Revoked"
            cert["date_revocation"] = datetime.now().strftime("%Y-%m-%d")

    return redirect("/")

if __name__ == "__main__":
    app.run(debug=True, port=5001)